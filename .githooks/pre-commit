#!/bin/sh
# Pre-commit hook: run full test suite before allowing commit.
# Installed via: git config core.hooksPath .githooks

echo "Running tests before commit..."
npm test 2>&1

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Commit aborted."
  echo "   Fix the failing tests, then try again."
  exit 1
fi
