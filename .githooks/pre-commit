#!/bin/sh
# Pre-commit hook: type check + full test suite before allowing commit.
# Installed via: git config core.hooksPath .githooks

echo "Type checking..."
npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "Type check failed. Commit aborted."
  echo "   Fix the type errors, then try again."
  exit 1
fi

echo "Running tests..."
npm test 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "Tests failed. Commit aborted."
  echo "   Fix the failing tests, then try again."
  exit 1
fi
