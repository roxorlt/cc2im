{
  "name": "cc2im",
  "version": "0.2.0",
  "description": "IM gateway for multiple local Claude Code instances",
  "author": "roxorlt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roxorlt/cc2im.git"
  },
  "homepage": "https://github.com/roxorlt/cc2im#readme",
  "keywords": ["claude", "claude-code", "wechat", "weixin", "im", "gateway", "mcp"],
  "type": "module",
  "bin": {
    "cc2im": "dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "dev:hub": "npx tsx src/hub/index.ts",
    "dev:spoke": "npx tsx src/spoke/index.ts",
    "prepare": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@pinixai/weixin-bot": "^1.2.0",
    "better-sqlite3": "^12.8.0",
    "croner": "^10.0.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.21.0",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
